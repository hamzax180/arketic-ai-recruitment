{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py?$1"
    },
    {
      "src": "/token",
      "dest": "backend/main.py"
    },
    {
      "src": "/signup",
      "dest": "backend/main.py"
    },
    {
      "src": "/me",
      "dest": "backend/main.py"
    },
    {
      "src": "/jobs",
      "dest": "backend/main.py"
    },
    {
      "src": "/analyze-cv",
      "dest": "backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}
